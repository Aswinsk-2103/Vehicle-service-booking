import React, { useEffect, useState } from 'react';
import { getGarageQueue } from '../../services/api';
import StatusBadge from '../../components/StatusBadge';
import Loader from '../../components/Loader';

const GarageQueue = () => {
  const [queue, setQueue] = useState([]);
  const [loading, setLoading] = useState(true);

  const fetchQueue = () => getGarageQueue().then(r => setQueue(r.data)).finally(() => setLoading(false));
  useEffect(() => { fetchQueue(); const interval = setInterval(fetchQueue, 30000); return () => clearInterval(interval); }, []);

  if (loading) return <Loader />;

  return (
    <div className="max-w-5xl mx-auto px-4 py-8">
      <div className="flex items-center justify-between mb-6">
        <h1 className="text-2xl font-bold text-gray-900">Garage Queue Monitor</h1>
        <button onClick={fetchQueue} className="btn-secondary text-sm">🔄 Refresh</button>
      </div>

      <div className="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
        <div className="card text-center border-l-4 border-blue-500">
          <p className="text-3xl font-bold text-blue-600">{queue.length}</p>
          <p className="text-sm text-gray-500">Vehicles in Queue</p>
        </div>
        <div className="card text-center border-l-4 border-yellow-500">
          <p className="text-3xl font-bold text-yellow-600">{queue.filter(q => q.status === 'Repair in Progress').length}</p>
          <p className="text-sm text-gray-500">Under Repair</p>
        </div>
        <div className="card text-center border-l-4 border-green-500">
          <p className="text-3xl font-bold text-green-600">{queue.filter(q => q.status === 'Testing').length}</p>
          <p className="text-sm text-gray-500">In Testing</p>
        </div>
      </div>

      {queue.length === 0 ? (
        <div className="card text-center py-12 text-gray-400">
          <p className="text-5xl mb-3">🏁</p>
          <p>No vehicles currently in service</p>
        </div>
      ) : (
        <div className="space-y-4">
          {queue.map(item => (
            <div key={item._id} className="card flex items-center gap-4">
              <div className="w-10 h-10 bg-blue-100 text-blue-700 rounded-full flex items-center justify-center font-bold text-lg flex-shrink-0">
                {item.position}
              </div>
              <div className="flex-1">
                <div className="flex items-center gap-3 flex-wrap">
                  <h3 className="font-semibold">{item.vehicleId?.brand} {item.vehicleId?.model}</h3>
                  <span className="font-mono text-sm text-gray-500">{item.vehicleId?.vehicleNumber}</span>
                  <StatusBadge status={item.status} />
                </div>
                <p className="text-sm text-gray-500 mt-1">
                  Customer: {item.customerId?.name} • {item.customerId?.phone}
                  {item.mechanicId && ` • Mechanic: ${item.mechanicId.name}`}
                </p>
              </div>
              <div className="text-right flex-shrink-0">
                <p className="text-sm font-medium text-orange-600">~{item.estimatedWaitMinutes} min</p>
                <p className="text-xs text-gray-400">Est. wait</p>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  );
};

export default GarageQueue;
