const mongoose = require('mongoose');

const serviceSlotSchema = new mongoose.Schema({
  date: { type: String, required: true }, // YYYY-MM-DD
  time: { type: String, required: true }, // HH:MM
  serviceType: {
    type: String,
    enum: ['Oil Change', 'Engine Service', 'Brake Check', 'General Service', 'Full Service'],
    required: true,
  },
  isAvailable: { type: Boolean, default: true },
  maxBookings: { type: Number, default: 1 },
  currentBookings: { type: Number, default: 0 },
}, { timestamps: true });

serviceSlotSchema.index({ date: 1, time: 1, serviceType: 1 }, { unique: true });

module.exports = mongoose.model('ServiceSlot', serviceSlotSchema);
