import React, { useEffect, useState } from 'react';
import { getSpareParts, createSparePart, updateSparePart } from '../../services/api';
import Loader from '../../components/Loader';
import toast from 'react-hot-toast';

const EMPTY_FORM = { name: '', partNumber: '', category: '', quantity: '', minStockLevel: 5, unitPrice: '', supplier: '' };

const Inventory = () => {
  const [parts, setParts] = useState([]);
  const [loading, setLoading] = useState(true);
  const [showForm, setShowForm] = useState(false);
  const [form, setForm] = useState(EMPTY_FORM);
  const [editId, setEditId] = useState(null);
  const [submitting, setSubmitting] = useState(false);

  const fetchParts = () => getSpareParts().then(r => setParts(r.data)).finally(() => setLoading(false));
  useEffect(() => { fetchParts(); }, []);

  const handleSubmit = async (e) => {
    e.preventDefault();
    setSubmitting(true);
    try {
      if (editId) {
        await updateSparePart(editId, form);
        toast.success('Part updated!');
      } else {
        await createSparePart(form);
        toast.success('Part added!');
      }
      setShowForm(false);
      setForm(EMPTY_FORM);
      setEditId(null);
      fetchParts();
    } catch (err) {
      toast.error(err.response?.data?.message || 'Failed to save');
    } finally {
      setSubmitting(false);
    }
  };

  const lowStockParts = parts.filter(p => p.quantity <= p.minStockLevel);

  if (loading) return <Loader />;

  return (
    <div className="max-w-6xl mx-auto px-4 py-8">
      <div className="flex items-center justify-between mb-6">
        <h1 className="text-2xl font-bold text-gray-900">Spare Parts Inventory</h1>
        <button onClick={() => { setShowForm(true); setEditId(null); setForm(EMPTY_FORM); }} className="btn-primary">+ Add Part</button>
      </div>

      {lowStockParts.length > 0 && (
        <div className="bg-red-50 border border-red-200 rounded-lg p-4 mb-6">
          <p className="text-red-700 font-medium">⚠️ Low Stock Alert: {lowStockParts.length} item(s) need restocking</p>
          <p className="text-red-600 text-sm mt-1">{lowStockParts.map(p => p.name).join(', ')}</p>
        </div>
      )}

      {showForm && (
        <div className="card mb-6">
          <h2 className="text-lg font-semibold mb-4">{editId ? 'Edit Part' : 'Add New Part'}</h2>
          <form onSubmit={handleSubmit} className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {[
              { key: 'name', label: 'Part Name', placeholder: 'Engine Oil Filter' },
              { key: 'partNumber', label: 'Part Number', placeholder: 'EF-001' },
              { key: 'category', label: 'Category', placeholder: 'Filters' },
              { key: 'quantity', label: 'Quantity', placeholder: '50', type: 'number' },
              { key: 'minStockLevel', label: 'Min Stock Level', placeholder: '5', type: 'number' },
              { key: 'unitPrice', label: 'Unit Price (₹)', placeholder: '250', type: 'number' },
              { key: 'supplier', label: 'Supplier', placeholder: 'ABC Suppliers' },
            ].map(({ key, label, placeholder, type }) => (
              <div key={key}>
                <label className="block text-sm font-medium text-gray-700 mb-1">{label}</label>
                <input type={type || 'text'} className="input-field" placeholder={placeholder}
                  required={['name', 'quantity', 'unitPrice'].includes(key)}
                  value={form[key]} onChange={(e) => setForm({ ...form, [key]: e.target.value })} />
              </div>
            ))}
            <div className="sm:col-span-2 lg:col-span-3 flex gap-3">
              <button type="submit" disabled={submitting} className="btn-primary">{submitting ? 'Saving...' : 'Save Part'}</button>
              <button type="button" onClick={() => setShowForm(false)} className="btn-secondary">Cancel</button>
            </div>
          </form>
        </div>
      )}

      <div className="card overflow-x-auto">
        <table className="w-full text-sm">
          <thead>
            <tr className="bg-gray-50 text-left">
              <th className="p-3 font-medium">Part Name</th>
              <th className="p-3 font-medium">Part #</th>
              <th className="p-3 font-medium">Category</th>
              <th className="p-3 font-medium">Qty</th>
              <th className="p-3 font-medium">Min Stock</th>
              <th className="p-3 font-medium">Unit Price</th>
              <th className="p-3 font-medium">Status</th>
              <th className="p-3 font-medium">Action</th>
            </tr>
          </thead>
          <tbody>
            {parts.map(p => (
              <tr key={p._id} className={`border-t hover:bg-gray-50 ${p.quantity <= p.minStockLevel ? 'bg-red-50' : ''}`}>
                <td className="p-3 font-medium">{p.name}</td>
                <td className="p-3 text-gray-500 font-mono text-xs">{p.partNumber || '-'}</td>
                <td className="p-3 text-gray-500">{p.category || '-'}</td>
                <td className="p-3 font-bold">{p.quantity}</td>
                <td className="p-3 text-gray-500">{p.minStockLevel}</td>
                <td className="p-3">₹{p.unitPrice}</td>
                <td className="p-3">
                  <span className={`text-xs px-2 py-0.5 rounded-full font-medium ${p.quantity <= p.minStockLevel ? 'bg-red-100 text-red-700' : 'bg-green-100 text-green-700'}`}>
                    {p.quantity <= p.minStockLevel ? '⚠️ Low' : '✅ OK'}
                  </span>
                </td>
                <td className="p-3">
                  <button onClick={() => { setForm({ name: p.name, partNumber: p.partNumber || '', category: p.category || '', quantity: p.quantity, minStockLevel: p.minStockLevel, unitPrice: p.unitPrice, supplier: p.supplier || '' }); setEditId(p._id); setShowForm(true); }}
                    className="text-blue-600 hover:underline text-xs">Edit</button>
                </td>
              </tr>
            ))}
            {parts.length === 0 && <tr><td colSpan={8} className="p-8 text-center text-gray-400">No parts in inventory</td></tr>}
          </tbody>
        </table>
      </div>
    </div>
  );
};

export default Inventory;
